pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/abishar605/ABISHA_AGILE.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t static-app .'
            }
        }

        stage('Run Container') {
            steps {
                bat 'docker rm -f static-container || true'
                bat 'docker run -d -p 8081:80 --name static-container static-app'
            }
        }

    }
}
