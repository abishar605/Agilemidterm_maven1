2. Dockerfile
FROM nginx:latest
COPY index.html /usr/share/nginx/html/index.html
3. deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: static-app
spec:
  replicas: 2
  selector:
    matchLabels:
      app: static-app
  template:
    metadata:
      labels:
        app: static-app
    spec:
      containers:
      - name: static-app
        image: static-app
        imagePullPolicy: Never
        ports:
        - containerPort: 80
4. service.yaml
apiVersion: v1
kind: Service
metadata:
  name: static-service
spec:
  type: NodePort
  selector:
    app: static-app
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30007
